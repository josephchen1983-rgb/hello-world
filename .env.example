# 服务器配置
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here

# 服务器端口
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
WEBSOCKET_PORT=5001

# MySQL 数据库
MYSQL_HOST=mqtt_mysql
MYSQL_PORT=3306
MYSQL_USER=mqtt_user
MYSQL_PASSWORD=mqtt@123
MYSQL_DATABASE=mqtt_web

# InfluxDB 配置
INFLUXDB_HOST=mqtt_influxdb
INFLUXDB_PORT=8086
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=admin@123
INFLUXDB_DATABASE=mqtt_data

# Redis 配置
REDIS_HOST=mqtt_redis
REDIS_PORT=6379
REDIS_DB=0

# MQTT 配置
MQTT_BROKER_HOST=emqx
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=mqtt_web_client
MQTT_TOPICS=sensor/#,device/#,alert/#

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 跨域配置
CORS_ORIGINS=*

# 其他配置
TIMEZONE=Asia/Shanghai
MAX_CONTENT_LENGTH=16777216
SESSION_TIMEOUT=3600